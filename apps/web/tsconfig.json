      "erp-pro-ui": ["../../packages/ui/src/index.ts"],
      "erp-pro-ui/catalog": ["../../packages/ui/src/catalog.ts"],
      "erp-pro-ui/docs": ["../../packages/ui/src/docs.ts"]
    }
  },
  "include": ["src", "vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}
