{
  "name": "storybook",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env -- sh -c 'storybook dev -p $STORYBOOK_PORT --no-open'",
    "storybook": "dotenv -e .env -- sh -c 'storybook dev -p $STORYBOOK_PORT --no-open'",
    "build": "pnpm --dir ../.. --filter erp-pro-ui story:check && STORYBOOK_STATIC_BUILD=true storybook build",
    "lint": "eslint .",
    "typecheck": "pnpm --dir ../.. --filter erp-pro-ui story:check && tsc --noEmit",
    "build-storybook": "pnpm --dir ../.. --filter erp-pro-ui story:check && STORYBOOK_STATIC_BUILD=true storybook build"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "erp-pro-ui": "workspace:*"
  },
  "devDependencies": {
    "@erp-pro/tsconfig": "workspace:*",
    "@erp-pro/eslint-config": "workspace:*",
    "@erp-pro/vite-config": "workspace:*",
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/addon-links": "^10.3.4",
    "@storybook/addon-onboarding": "^10.3.4",
    "@storybook/addon-vitest": "^10.3.4",
    "@storybook/react-vite": "^10.3.4",
    "@tailwindcss/vite": "^4.2.2",
    "storybook": "^10.3.4",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.2.0",
    "eslint-plugin-storybook": "^10.3.4",
    "vitest": "^4.1.2"
  }
}
