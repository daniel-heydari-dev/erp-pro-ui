{
  "name": "erp-pro-ui",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/daniel-heydari-dev/erp-pro-ui"
  },
  "homepage": "https://daniel-heydari-dev.github.io/erp-pro-ui/",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=web",
    "dev:api": "turbo dev --filter=api",
    "storybook": "turbo storybook --filter=storybook",
    "lint": "pnpm lint:all",
    "lint:all": "turbo lint",
    "release": "pnpm --filter ./packages/ui build && pnpm --filter ./packages/ui publish --no-git-checks --access public",
    "typecheck": "pnpm typecheck:all",
    "typecheck:all": "turbo typecheck",
    "format": "pnpm format:all",
    "format:all": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown",
    "clean": "turbo clean && rm -rf node_modules",
    "install:all": "pnpm install"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.8.1",
    "turbo": "^2.9.4",
    "typescript": "^6.0.2"
  }
}
